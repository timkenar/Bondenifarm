# Django settings
SECRET_KEY=generate-a-50-char-random-string-here
DEBUG=False
ALLOWED_HOSTS=api.yourdomain.com

# Database (internal Docker network)
DATABASE=postgres
DATABASE_URL=postgresql://bondenifarm:your-secure-password@db:5432/bondenifarm
SQL_HOST=db
SQL_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/1

# CORS - your frontend domain(s). Comma-separated, no trailing slash.
# Must include scheme. Required for the React app to call this API.
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# CSRF - origins trusted to submit unsafe (POST/PUT/PATCH/DELETE) requests.
# Should mirror CORS_ALLOWED_ORIGINS for a separated frontend/backend setup.
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Logging
LOG_LEVEL=WARNING
DJANGO_LOG_LEVEL=WARNING
